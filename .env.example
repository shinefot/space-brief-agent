# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...

# Model routing (override only if you want to). Defaults are sensible.
MODEL_SCORE=claude-haiku-4-5-20251001     # cheap, high-volume relevance scoring
MODEL_ANALYZE=claude-sonnet-4-6           # per-pillar analytic write-ups
MODEL_SYNTHESIZE=claude-opus-4-8          # exec summary + asymmetry-ledger reasoning

# ---- Scope / tuning ----
LOOKBACK_DAYS=7          # window of news to pull each run
MIN_SIGNIFICANCE=2       # drop clusters scored below this (1-5 scale)

# ---- Launch Library 2 (optional; leave key blank to use the free 15 req/hr tier) ----
LL2_BASE=https://ll.thespacedevs.com/2.3.0
LL2_API_KEY=

# ---- Space-Track (optional; for the orbital RPO/maneuver module) ----
# Free account at https://www.space-track.org/auth/createAccount
SPACETRACK_USER=
SPACETRACK_PASS=

# ---- Email delivery (SMTP; works with Gmail app-passwords, Fastmail, Resend SMTP, etc.) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com            # comma-separated for multiple recipients
